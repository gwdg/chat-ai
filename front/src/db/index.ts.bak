import Dexie, { Table } from 'dexie'

export type Role = 'user' | 'assistant' | 'system' | 'info'

export interface ConversationRow {
  id: string
  title: string
  lastModified: number
  messageCount: number
}

export interface MessageRow {
  id: string
  conversationId: string
  idx: number
  role: Role
  content: string
  createdAt: number
  meta?: any
}

export type ConversationMeta = ConversationRow

export type MessageInput = {
  id?: string
  idx: number
  role: Role
  content: string
  createdAt?: number
  meta?: any
}

class AppDB extends Dexie {
  conversations!: Table<ConversationRow, string>
  messages!: Table<MessageRow, string>

  constructor() {
    super('app-db')
    this.version(1).stores({
      // Primary key: id. Indexes: lastModified, title for quick listing/search
      conversations: 'id, lastModified, title',
      // Primary key: id. Indexes: conversationId, compound [conversationId+idx] for ordered pagination
      messages: 'id, conversationId, [conversationId+idx], idx, createdAt',
    })
    this.conversations = this.table('conversations')
    this.messages = this.table('messages')
  }
}

export const db = new AppDB()

function genId(): string {
  try {
    if (typeof crypto !== 'undefined' && 'randomUUID' in crypto) {
      return crypto.randomUUID()
    }
  } catch {}
  return 'id-' + Math.random().toString(36).slice(2) + Date.now().toString(36)
}

// Conversation meta operations

export async function listConversationMetas(): Promise<ConversationMeta[]> {
  return db.conversations.orderBy('lastModified').reverse().toArray()
}

export async function getConversationMeta(id: string): Promise<ConversationMeta | undefined> {
  return db.conversations.get(id)
}

export async function createConversation(title = 'Untitled Conversation'): Promise<string> {
  const id = genId()
  const now = Date.now()
  await db.conversations.add({ id, title, lastModified: now, messageCount: 0 })
  return id
}

export async function renameConversation(id: string, title: string): Promise<void> {
  await db.conversations.update(id, { title, lastModified: Date.now() })
}

export async function touchConversation(id: string): Promise<void> {
  await db.conversations.update(id, { lastModified: Date.now() })
}

export async function deleteConversation(id: string): Promise<void> {
  await db.transaction('rw', db.messages, db.conversations, async () => {
    await db.messages.where('conversationId').equals(id).delete()
    await db.conversations.delete(id)
  })
}

// Message operations

export async function getMessages(
  conversationId: string,
  offset = 0,
  limit = 200
): Promise<MessageRow[]> {
  return db.messages
    .where('[conversationId+idx]')
    .between([conversationId, Dexie.minKey], [conversationId, Dexie.maxKey])
    .offset(offset)
    .limit(limit)
    .toArray()
}

