export async function getLastMessage(conversationId: string): Promise<MessageRow | undefined> {
  return db.messages
    .where('[conversationId+idx]')
    .between([conversationId, Dexie.minKey], [conversationId, Dexie.maxKey])
    .last()
}

export async function appendMessage(
  conversationId: string,
  msg: Omit<MessageInput, 'idx'> & { idx?: number }
): Promise<{ id: string; idx: number }> {
  return db.transaction('rw', db.messages, db.conversations, async () => {
    const now = Date.now()
    let idx = msg.idx ?? 0
    if (msg.idx == null) {
      const last = await getLastMessage(conversationId)
      idx = (last?.idx ?? -1) + 1
    }
    const id = msg.id ?? genId()
    await db.messages.add({
      id,
      conversationId,
      idx,
      role: msg.role,
      content: msg.content,
      createdAt: msg.createdAt ?? now,
      meta: msg.meta,
    })
    const conv = await db.conversations.get(conversationId)
    await db.conversations.update(conversationId, {
      updatedAt: now,
      messageCount: (conv?.messageCount ?? 0) + 1,
    })
    return { id, idx }
  })
}

export async function upsertMessages(
  conversationId: string,
  inputs: MessageInput[],
  options?: { bumpUpdatedAt?: boolean; recomputeCount?: boolean }
): Promise<void> {
  const now = Date.now()
  await db.transaction('rw', db.messages, db.conversations, async () => {
    const rows: MessageRow[] = inputs.map((m) => ({
      id: m.id ?? genId(),
      conversationId,
      idx: m.idx,
      role: m.role,
      content: m.content,
      createdAt: m.createdAt ?? now,
      meta: m.meta,
    }))
    await db.messages.bulkPut(rows)
    const patch: Partial<ConversationRow> = {}
    if (options?.bumpUpdatedAt !== false) patch.lastModified = now
    if (options?.recomputeCount) {
      const count = await db.messages.where('conversationId').equals(conversationId).count()
      patch.messageCount = count
    }
    if (Object.keys(patch).length) {
      await db.conversations.update(conversationId, patch)
    }
  })
}

export async function deleteMessages(
  conversationId: string,
  messageIds: string[],
  options?: { bumpUpdatedAt?: boolean; recomputeCount?: boolean }
): Promise<void> {
  const now = Date.now()
  await db.transaction('rw', db.messages, db.conversations, async () => {
    await db.messages.bulkDelete(messageIds)
    const patch: Partial<ConversationRow> = {}
    if (options?.bumpLastModified !== false) patch.lastModified = now
    if (options?.recomputeCount !== false) {
      const count = await db.messages.where('conversationId').equals(conversationId).count()
      patch.messageCount = count
    }
    await db.conversations.update(conversationId, patch)
  })
}

// Snapshot saver: make DB match the provided list (efficiently deletes removed messages)
export async function saveConversationSnapshot(
  conversationId: string,
  inputs: MessageInput[]
): Promise<void> {
  const now = Date.now()
  await db.transaction('rw', db.messages, db.conversations, async () => {
    // Normalize rows and ensure ids
    const rows: MessageRow[] = inputs.map((m) => ({
      id: m.id ?? genId(),
      conversationId,
      idx: m.idx,
      role: m.role,
      content: m.content,
      createdAt: m.createdAt ?? now,
      meta: m.meta,
    }))

    // Determine which existing messages to delete (not present in snapshot)
    const newIds = new Set(rows.map((r) => r.id))
    const existingIds = (await db.messages.where('conversationId').equals(conversationId).primaryKeys()) as string[]
    const toDelete = existingIds.filter((id) => !newIds.has(id))

    if (toDelete.length) {
      await db.messages.bulkDelete(toDelete)
    }
    if (rows.length) {
      await db.messages.bulkPut(rows)
    }

    await db.conversations.update(conversationId, {
      lastModified: now,
      messageCount: rows.length,
    })
  })
}

// Maintenance

export async function resetDatabase(): Promise<void> {
  await db.delete()
  // Recreate with the same schema
  await db.open()
}